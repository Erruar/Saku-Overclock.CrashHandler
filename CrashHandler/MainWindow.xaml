<Window x:Class="CrashHandler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrashHandler"
        mc:Ignorable="d" ResizeMode="NoResize" AllowsTransparency="True" MouseDown="MovingWin" Icon="/Images/xml.png"
        Title="Saku CrashHandler - crash errors app by Erruar" WindowStyle="None" Height="460" Width="800">
    <Window.Background>
        <LinearGradientBrush Opacity="1">
            <GradientStop Color="Aqua" Offset="0.1"/>
            <GradientStop Color="PaleGreen" Offset="0.5"/>
            <GradientStop Color="PaleGoldenrod" Offset="1.1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Window.Clip>
        <RectangleGeometry Rect="0,0,800,460" RadiusX="10" RadiusY="10"/>
    </Window.Clip>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" x:Name="UpperBorder">
            <Border.Background>
                <SolidColorBrush Color="White" Opacity="0.7"/>
            </Border.Background>
            <Grid HorizontalAlignment="Stretch" MouseMove="Grid_MouseMove">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                    <Image Width="32" Source="/Images/xml.png"/>
                    <StackPanel Margin="7,10,0,0" Orientation="Vertical">
                        <TextBlock x:Name="LogoName" FontWeight="Bold" FontSize="14" Text="Saku CrashHandler"/>
                        <TextBlock x:Name="LogoDescript" FontWeight="SemiBold" Text="Showing last application logs"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Grid>
                        <Image Margin="-2,0,0,0" Source="/Images/minimize.png" HorizontalAlignment="Left" Height="25" >

                        </Image>
                        <Ellipse Fill="Transparent" Height="20" Width="20" HorizontalAlignment="Left" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="minimizeApp" MouseEnter="Ellipse_MouseEnter" MouseLeave="Ellipse_MouseLeave">
                            <Ellipse.ToolTip>
                                Minimize
                            </Ellipse.ToolTip>
                        </Ellipse>
                    </Grid>
                    <Grid Margin="5,0,0,0">
                        <Image Margin="-2.7,0,0,0" Source="/Images/close.png" HorizontalAlignment="Left" Height="25">

                        </Image>
                        <Ellipse Fill="Transparent" Height="20" Width="20"  HorizontalAlignment="Left" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="closeApp" MouseEnter="Ellipse_MouseEnter" MouseLeave="Ellipse_MouseLeave">
                            <Ellipse.ToolTip>
                                Close
                            </Ellipse.ToolTip>
                        </Ellipse>
                    </Grid> 
                </StackPanel>
            </Grid>
        </Border>
        <Grid Margin="7,0,0,0" x:Name="ContentPresent" Grid.Row="1">
            
        </Grid>
    </Grid>
</Window>
